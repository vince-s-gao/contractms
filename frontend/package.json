{
  "name": "contract-management-frontend",
  "version": "1.0.0",
  "description": "合同管理系统前端项目",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm install --platform=linux --arch=arm64 && npm install -D sass && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path ../.gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "@vee-validate/i18n": "^4.10.0",
    "@vee-validate/rules": "^4.10.0",
    "axios": "^1.5.0",
    "element-plus": "^2.3.0",
    "pinia": "^2.1.0",
    "vee-validate": "^4.10.0",
    "vue": "^3.3.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^11.0.0",
    "@vue/tsconfig": "^0.4.0",
    "eslint": "^8.42.0",
    "eslint-plugin-vue": "^9.15.0",
    "prettier": "^3.0.0",
    "sass": "^1.97.3",
    "typescript": "~5.1.0",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
